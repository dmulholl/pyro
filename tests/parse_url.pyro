with result = parse_url("http://username:password@[ipv6addr]:8080/path.html?foo=bar&baz=bam#fragment") {
    assert result == URL as {
        scheme: "http",
        username: "username",
        password: "password",
        host: "ipv6addr",
        port: "8080",
        path: "/path.html",
        query: "foo=bar&baz=bam",
        fragment: "fragment",
    };
}

with result = parse_url("http://[ipv6addr]/") {
    assert result == URL as {
        scheme: "http",
        host: "ipv6addr",
        path: "/",
    };
}

with result = parse_url("http://[ipv6addr]") {
    assert result == URL as {
        scheme: "http",
        host: "ipv6addr",
        path: "",
    };
}

with result = parse_url("mailto:johndoe@example.com") {
    assert result == URL as {
        scheme: "mailto",
        path: "johndoe@example.com",
    };
}

with result = parse_url("/path1/path2/path3.html?foo=bar&baz=bam#fragment") {
    assert result == URL as {
        path: "/path1/path2/path3.html",
        query: "foo=bar&baz=bam",
        fragment: "fragment",
    };
}
