}

with result = parse_url("http://username:password@example.com:8080/path1/path2/path3.html?foo=bar&baz=bam") {
    assert result == URL as {
        scheme: "http",
        username: "username",
        password: "password",
        host: "example.com",
        port: "8080",
        path: "/path1/path2/path3.html",
        query: "foo=bar&baz=bam",
    };
}

with result = parse_url("http://username:password@example.com/?foo=bar&baz=bam") {
    assert result == URL as {
        scheme: "http",
        username: "username",
        password: "password",
        host: "example.com",
        path: "/",
        query: "foo=bar&baz=bam",
